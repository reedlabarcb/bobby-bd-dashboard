# ─── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=        # Required: OM parsing + AI synthesis
DB_PATH=./data/bobby.db   # Local: ./data/bobby.db, Railway: /data/bobby.db

# ─── Enrichment stack (all optional — pipeline degrades gracefully) ───
HUNTER_API_KEY=           # Email finder — hunter.io — active on Railway
APOLLO_API_KEY=           # Contact search — apollo.io — free: people/search + organizations/search only
PDL_API_KEY=              # Person enrichment — peopledatalabs.com — free: 100 lookups/month
APIFY_API_KEY=            # LinkedIn scraper — apify.com (apify~linkedin-profile-scraper actor)

# ─── Map (optional, /map page) ───
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Box (legacy OAuth path — leave blank to use the local watcher) ───
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REDIRECT_URI=http://localhost:3000/api/box/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for the Box-watcher uploader. When set, /api/process-document
# requires this secret in an X-Upload-Secret header for non-browser uploads.
UPLOAD_SECRET=

# ─── Auth (src/proxy.ts) ───
APP_PASSWORD=             # Shared password for /login. Blank = public.
AUTH_SECRET=              # HMAC secret for session cookie. Must be ≥16 chars.
